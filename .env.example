# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# AI Trust Layer (OpenAI gpt-4o-mini)
# Required for /api/ai/generate-summaries (HAEVN Insight + Connection
# Summary). Without it the endpoint returns 503 NO_API_KEY and the
# GenerateSummaryButton on /profile shows a "service not configured"
# toast. Get a key at https://platform.openai.com/api-keys and ensure
# the account has billing credits.
OPENAI_API_KEY=

# Twilio SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
CRON_SECRET=

# Veriff ID Verification
# VERIFF_RETURN_URL must point at /onboarding/verification/return so
# the polling page can read profiles.verified and forward the user to
# /onboarding/verification-complete on approval. Pointing it elsewhere
# (e.g. survey-intro) silently breaks the verification handoff.
VERIFF_API_KEY=
VERIFF_SIGNATURE_KEY=
VERIFF_BASE_URL=https://stationapi.veriff.com
VERIFF_RETURN_URL=http://localhost:3000/onboarding/verification/return

# Lemonsqueezy Payment
# One-time payments for fixed-duration HAEVN+ access (merchant of record).
# The two HAEVN+ product variants are hardcoded as defaults in
# lib/lemonsqueezy.ts so checkout works without these set; override here/Vercel
# only if the variant ids change.
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=375655
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_VARIANT_ID_PLUS_6=1106116
LEMONSQUEEZY_VARIANT_ID_PLUS_12=1106168
# Legacy single-variant var (optional; falls back to the 6-month variant).
LEMONSQUEEZY_VARIANT_ID_PLUS=

# Feature flags
# When true, ID verification is mandatory at the end of onboarding.
# Skip button is hidden and middleware redirects unverified users
# back to /onboarding/verification before allowing dashboard access.
# Default: false (verification is skippable during rollout).
NEXT_PUBLIC_REQUIRE_VERIFICATION=false